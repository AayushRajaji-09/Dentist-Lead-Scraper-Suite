!zen-code-ambience/
!zen-ambiator.ps1
!zen-ambiator.zsh
!zen-ambiator-macos.command
!zen-ambiator-macos.app/
!vscode-extension/
!docs/chrome/
!docs/vscode/
!docs/macos/
!docs/index.html
!docs/manifest.json
!docs/sw.js
!docs/icons/
!INSTALL.md

# Dentist Lead Scraper Suite files
!free_dentist_scraper.py
!dentist_lead_suite_gui.py
!run_logger.py
!run_history.json
!run_log.csv
!HOW_TO_USE.md
!requirements.txt

# Local environment files (do NOT commit your real keys)
.env
.env.local
.env.*.local
